{
  "name": "millipress/millirules",
  "description": "A declarative rule engine for PHP that turns complex conditional logic into readable when-then rules. Features a fluent builder API, lazy-loaded context for performance, smart operator inference, and works seamlessly in pure PHP or WordPress.",
  "type": "library",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "Philipp Wellmer",
      "email": "hello@millipress.com"
    }
  ],
  "require": {
    "php": ">=7.4",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "pestphp/pest": "^2.0",
    "squizlabs/php_codesniffer": "^3.7",
    "phpstan/phpstan": "^1.10",
    "szepeviktor/phpstan-wordpress": "^1.3",
    "brainmaestro/composer-git-hooks": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "MilliRules\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "MilliRules\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": [
      "@test:fix",
      "@test:lint",
      "@test:phpstan",
      "@test:unit"
    ],
    "test:unit": "pest",
    "test:phpstan": "phpstan --memory-limit=512M",
    "test:lint": "phpcs --standard=phpcs.xml.dist -s",
    "test:fix": "phpcbf --standard=phpcs.xml.dist",
    "cghooks": [
      "vendor/bin/cghooks"
    ]
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "extra": {
    "hooks": {
      "config": {
        "stop-on-failure": ["pre-push"]
      },
      "pre-commit": [
        "composer test:fix"
      ],
      "pre-push": [
        "composer validate --no-check-all --no-check-publish",
        "composer test"
      ],
      "post-merge": [
        "composer install"
      ]
    }
  }
}
